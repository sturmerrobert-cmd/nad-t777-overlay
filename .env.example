# Phase 0 needs only DEVICE_IP. Copy to .env and fill in.
# Use the explicit LAN IP of the receiver, NOT an mDNS/.local name.
DEVICE_IP=

# --- Filled in AFTER Phase 0 discovery (Phase 1 volume safety) ---
# MAX_VOLUME_DB=        # required to start the backend; no default
# MAX_STEP_DB=5
# WARN_VOLUME_DB=
# CLAMP_ON_OBSERVED=false
# VOLUME_WATCHDOG=false
# ZONE2_MAX_VOLUME_DB=  # Zone 2's own cap; falls back to MAX_VOLUME_DB if unset
# ZONE2_WARN_VOLUME_DB= # optional; falls back to WARN_VOLUME_DB if unset

# --- Network exposure (security) ---
# Default: loopback only (127.0.0.1) — the app controls an amplifier and must not
# be reachable from the LAN or from websites you visit. A Host-header allowlist
# also blocks DNS-rebinding. Set ALLOW_LAN=1 ONLY if you want to reach the UI from
# another device on your LAN (e.g. a phone) — and consider an access token then.
# ALLOW_LAN=false
